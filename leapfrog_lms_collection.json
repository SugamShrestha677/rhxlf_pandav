    {
      "name": "🔐 1. SUPER ADMIN FLOW",
      "item": [
        {
          "name": "1.1 - Super Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200) {",
                  "    // Save tokens to variables",
                  "    pm.collectionVariables.set('access_token', response.tokens.access);",
                  "    pm.collectionVariables.set('refresh_token', response.tokens.refresh);",
                  "",
                  "    console.log('✅ Super Admin Login Successful');",
                  "    console.log('Role:', response.user.role);",
                  "    console.log('Email:', response.user.email);",
                  "    console.log('Must Change Password:', response.user.must_change_password);",
                  "    console.log('');",
                  "    console.log('🔑 Access Token saved to collection variables');",
                  "    console.log('🔑 Refresh Token saved to collection variables');",
                  "",
                  "    // Verify super admin privileges",
                  "    if (response.user.role === 'admin') {",
                  "        console.log('✅ Super Admin has admin role');",
                  "    }",
                  "",
                  "    // Verify no password change required for super admin",
                  "    if (response.user.must_change_password === false) {",
                  "        console.log('✅ Super Admin already has permanent password');",
                  "    }",
                  "}",
                  "",
                  "if (pm.response.code !== 200) {",
                  "    console.log('❌ Login Failed:', response);",
                  "    console.log('Did you create super admin via terminal?');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{super_admin_email}}\",\n  \"password\": \"{{super_admin_password}}\"\n}"
            },
            "url": {
