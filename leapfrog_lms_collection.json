    {
      "name": "🔄 3. FIRST LOGIN FLOW (Any New User)",
      "item": [
        {
          "name": "3.1 - Login with Temp Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200) {",
                  "    // Save tokens",
                  "    pm.collectionVariables.set('access_token', response.tokens.access);",
                  "    pm.collectionVariables.set('refresh_token', response.tokens.refresh);",
                  "",
                  "    console.log('✅ Login successful');",
                  "    console.log('Must Change Password:', response.user.must_change_password);",
                  "    console.log('');",
                  "",
                  "    if (response.user.must_change_password) {",
                  "        console.log('⚠️ User must change password!');",
                  "        console.log('Redirect to: ' + response.redirect_to);",
                  "        console.log('');",
                  "        console.log('👉 Now run \\\"First Login - Set Permanent Password\\\"');",
                  "    } else {",
                  "        console.log('✅ User already has permanent password');",
                  "    }",
                  "} else {",
                  "    console.log('❌ Login failed:', response);",
                  "    console.log('Did you enter the correct temp password?');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{student_email}}\",\n  \"password\": \"TEMP_PASSWORD_FROM_EMAIL\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "accounts",
                "auth",
                "login"
              ]
            },
            "description": "🔴 IMPORTANT: Replace TEMP_PASSWORD_FROM_EMAIL with the actual temp password from the email.\n\nEmail subject: 'Welcome to Leapfrog Connect - Your Account Credentials'\n\nCheck: student@gmail.com (or whatever personal email was used)\n\nIf using console email backend, check Django terminal for the password."
          },
          "response": []
        },
        {
          "name": "3.2 - First Login - Set Permanent Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200) {",
                  "    // Save new tokens (old ones invalidated)",
                  "    pm.collectionVariables.set('access_token', response.tokens.access);",
                  "    pm.collectionVariables.set('refresh_token', response.tokens.refresh);",
                  "",
                  "    console.log('✅ Password set successfully!');",
                  "    console.log('Message:', response.message);",
                  "    console.log('');",
                  "    console.log('🔑 New tokens generated');",
                  "    console.log('✅ User can now use the platform normally');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_password\": \"{{new_password}}\",\n  \"confirm_password\": \"{{new_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/auth/first-login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "accounts",
                "auth",
                "first-login"
              ]
            },
            "description": "Set permanent password on first login. Must be done after login with temp password. New tokens are generated."
          },
          "response": []
        }
      ],
      "description": "Test the first login and password change flow for newly created users"
    },
