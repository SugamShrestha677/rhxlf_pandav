        {
          "name": "Set Variables",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Use these variables throughout the collection",
                  "pm.collectionVariables.set('base_url', 'http://localhost:8000');",
                  "pm.collectionVariables.set('access_token', '');",
                  "pm.collectionVariables.set('refresh_token', '');",
                  "pm.collectionVariables.set('course_id', '');",
                  "pm.collectionVariables.set('module_id', '');",
                  "pm.collectionVariables.set('content_id', '');",
                  "pm.collectionVariables.set('enrollment_id', '');",
                  "pm.collectionVariables.set('assessment_id', '');",
                  "",
                  "console.log('✅ Variables initialized');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/accounts/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "accounts", "auth", "login"]
            }
          }
        }
      ]
